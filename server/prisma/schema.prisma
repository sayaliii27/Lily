generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model WardrobeItem {
  id        String   @id @default(cuid())
  userId    String
  url       String
  category  String
  createdAt DateTime @default(now())
}

model SavedLook {
  id        String   @id @default(cuid())
  userId    String
  top       String?
  bottom    String?
  outerwear String?
  shoes     String?
  bag       String?
  extras    String?
  createdAt DateTime @default(now())
}